{"metadata": {".zgroup": {"zarr_format": 2}, ".zattrs": {"id": "noaa-nbm-conus-analysis-sample", "title": "NOAA NBM CONUS Analysis \u2014 short sample (full-res, GitHub-hosted)", "description": "National Blend of Models (NBM) CONUS daily historical analysis: one best-estimate value per calendar day on the native ~2.5 km Lambert conformal grid. Built from lead-day 1 of each 00z NBM forecast (shortest lead valid on the day). Variables: tmean/tmax/tmin (degC), precip (mm), srad (MJ/m^2/day).", "version": "0.1.0", "provider": "NOAA", "model": "NBM", "variant": "conus-analysis", "analysis_construction": "Best estimate for day D = lead_day 1 of the 00z init on day D.", "source": "https://noaa-nbm-grib2-pds.s3.amazonaws.com/", "license": "CC-BY-4.0 (derived); source NOAA NBM is public domain", "attribution": "NOAA NBM via AWS Open Data; layout inspired by dynamical.org", "resolution": "Native ~2.5 km Lambert conformal (2345 x 1597), no coarsening", "window": "Rolling last 7 days (full resolution)", "hosting": "Committed directly to this GitHub repo (free, no object store)", "data_status": "Real NBM-derived analysis at full resolution."}, "latitude/.zattrs": {"long_name": "Latitude", "standard_name": "latitude", "units": "degrees_north", "_ARRAY_DIMENSIONS": ["y", "x"]}, "latitude/.zarray": {"shape": [1597, 2345], "chunks": [200, 587], "dtype": "<f4", "fill_value": "NaN", "order": "C", "filters": null, "dimension_separator": ".", "compressor": {"id": "blosc", "cname": "lz4", "clevel": 5, "shuffle": 1, "blocksize": 0}, "zarr_format": 2}, "longitude/.zattrs": {"long_name": "Longitude", "standard_name": "longitude", "units": "degrees_east", "_ARRAY_DIMENSIONS": ["y", "x"]}, "longitude/.zarray": {"shape": [1597, 2345], "chunks": [200, 587], "dtype": "<f4", "fill_value": "NaN", "order": "C", "filters": null, "dimension_separator": ".", "compressor": {"id": "blosc", "cname": "lz4", "clevel": 5, "shuffle": 1, "blocksize": 0}, "zarr_format": 2}, "precip/.zattrs": {"units": "mm", "long_name": "Daily total precipitation", "standard_name": "precipitation_amount", "coordinates": "latitude longitude spatial_ref", "_ARRAY_DIMENSIONS": ["time", "y", "x"]}, "precip/.zarray": {"shape": [7, 1597, 2345], "chunks": [1, 512, 512], "dtype": "<f4", "fill_value": "NaN", "order": "C", "filters": null, "dimension_separator": ".", "compressor": {"id": "blosc", "cname": "zstd", "clevel": 5, "shuffle": 1, "blocksize": 0}, "zarr_format": 2}, "spatial_ref/.zattrs": {"grid_mapping_name": "lambert_conformal_conic", "standard_parallel": [25.0, 25.0], "longitude_of_central_meridian": 265.0, "latitude_of_projection_origin": 25.0, "false_easting": 0.0, "false_northing": 0.0, "earth_radius": 6371200.0, "crs_wkt": "PROJCRS[\"unknown\",BASEGEOGCRS[\"unknown\",DATUM[\"unknown\",ELLIPSOID[\"unknown\",6371200,0,LENGTHUNIT[\"metre\",1,ID[\"EPSG\",9001]]]],PRIMEM[\"Greenwich\",0,ANGLEUNIT[\"degree\",0.0174532925199433],ID[\"EPSG\",8901]]],CONVERSION[\"unknown\",METHOD[\"Lambert Conic Conformal (2SP)\",ID[\"EPSG\",9802]],PARAMETER[\"Latitude of false origin\",25,ANGLEUNIT[\"degree\",0.0174532925199433],ID[\"EPSG\",8821]],PARAMETER[\"Longitude of false origin\",265,ANGLEUNIT[\"degree\",0.0174532925199433],ID[\"EPSG\",8822]],PARAMETER[\"Latitude of 1st standard parallel\",25,ANGLEUNIT[\"degree\",0.0174532925199433],ID[\"EPSG\",8823]],PARAMETER[\"Latitude of 2nd standard parallel\",25,ANGLEUNIT[\"degree\",0.0174532925199433],ID[\"EPSG\",8824]],PARAMETER[\"Easting at false origin\",0,LENGTHUNIT[\"metre\",1],ID[\"EPSG\",8826]],PARAMETER[\"Northing at false origin\",0,LENGTHUNIT[\"metre\",1],ID[\"EPSG\",8827]]],CS[Cartesian,2],AXIS[\"(E)\",east,ORDER[1],LENGTHUNIT[\"metre\",1,ID[\"EPSG\",9001]]],AXIS[\"(N)\",north,ORDER[2],LENGTHUNIT[\"metre\",1,ID[\"EPSG\",9001]]]]", "_ARRAY_DIMENSIONS": []}, "spatial_ref/.zarray": {"shape": [], "chunks": [], "dtype": "<i8", "fill_value": null, "order": "C", "filters": null, "dimension_separator": ".", "compressor": {"id": "blosc", "cname": "lz4", "clevel": 5, "shuffle": 1, "blocksize": 0}, "zarr_format": 2}, "srad/.zattrs": {"units": "MJ m-2 day-1", "long_name": "Daily mean downward shortwave radiation as daily energy", "standard_name": "surface_downwelling_shortwave_flux_in_air", "coordinates": "latitude longitude spatial_ref", "_ARRAY_DIMENSIONS": ["time", "y", "x"]}, "srad/.zarray": {"shape": [7, 1597, 2345], "chunks": [1, 512, 512], "dtype": "<f4", "fill_value": "NaN", "order": "C", "filters": null, "dimension_separator": ".", "compressor": {"id": "blosc", "cname": "zstd", "clevel": 5, "shuffle": 1, "blocksize": 0}, "zarr_format": 2}, "time/.zattrs": {"long_name": "Valid date (analysis)", "standard_name": "time", "units": "days since 2026-06-07", "calendar": "proleptic_gregorian", "_ARRAY_DIMENSIONS": ["time"]}, "time/.zarray": {"shape": [7], "chunks": [7], "dtype": "<i8", "fill_value": null, "order": "C", "filters": null, "dimension_separator": ".", "compressor": {"id": "blosc", "cname": "lz4", "clevel": 5, "shuffle": 1, "blocksize": 0}, "zarr_format": 2}, "tmax/.zattrs": {"units": "degC", "long_name": "Daily maximum 2 m temperature", "standard_name": "air_temperature", "coordinates": "latitude longitude spatial_ref", "_ARRAY_DIMENSIONS": ["time", "y", "x"]}, "tmax/.zarray": {"shape": [7, 1597, 2345], "chunks": [1, 512, 512], "dtype": "<f4", "fill_value": "NaN", "order": "C", "filters": null, "dimension_separator": ".", "compressor": {"id": "blosc", "cname": "zstd", "clevel": 5, "shuffle": 1, "blocksize": 0}, "zarr_format": 2}, "tmean/.zattrs": {"units": "degC", "long_name": "Daily mean 2 m temperature", "standard_name": "air_temperature", "coordinates": "latitude longitude spatial_ref", "_ARRAY_DIMENSIONS": ["time", "y", "x"]}, "tmean/.zarray": {"shape": [7, 1597, 2345], "chunks": [1, 512, 512], "dtype": "<f4", "fill_value": "NaN", "order": "C", "filters": null, "dimension_separator": ".", "compressor": {"id": "blosc", "cname": "zstd", "clevel": 5, "shuffle": 1, "blocksize": 0}, "zarr_format": 2}, "tmin/.zattrs": {"units": "degC", "long_name": "Daily minimum 2 m temperature", "standard_name": "air_temperature", "coordinates": "latitude longitude spatial_ref", "_ARRAY_DIMENSIONS": ["time", "y", "x"]}, "tmin/.zarray": {"shape": [7, 1597, 2345], "chunks": [1, 512, 512], "dtype": "<f4", "fill_value": "NaN", "order": "C", "filters": null, "dimension_separator": ".", "compressor": {"id": "blosc", "cname": "zstd", "clevel": 5, "shuffle": 1, "blocksize": 0}, "zarr_format": 2}, "x/.zattrs": {"units": "meters", "long_name": "X coordinate (Lambert conformal projection)", "standard_name": "projection_x_coordinate", "_ARRAY_DIMENSIONS": ["x"]}, "x/.zarray": {"shape": [2345], "chunks": [2345], "dtype": "<f8", "fill_value": "NaN", "order": "C", "filters": null, "dimension_separator": ".", "compressor": {"id": "blosc", "cname": "lz4", "clevel": 5, "shuffle": 1, "blocksize": 0}, "zarr_format": 2}, "y/.zattrs": {"units": "meters", "long_name": "Y coordinate (Lambert conformal projection)", "standard_name": "projection_y_coordinate", "_ARRAY_DIMENSIONS": ["y"]}, "y/.zarray": {"shape": [1597], "chunks": [1597], "dtype": "<f8", "fill_value": "NaN", "order": "C", "filters": null, "dimension_separator": ".", "compressor": {"id": "blosc", "cname": "lz4", "clevel": 5, "shuffle": 1, "blocksize": 0}, "zarr_format": 2}}, "zarr_consolidated_format": 1}